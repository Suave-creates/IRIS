{
  "name": "@iris/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts up",
    "db:status": "tsx src/db/migrate.ts status",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:demo": "tsx src/db/seed-demo.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@iris/shared": "*",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "mysql2": "^3.11.3",
    "nanoid": "^5.0.7",
    "pino": "^9.5.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "pino-pretty": "^11.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
