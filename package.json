{
  "name": "iris",
  "version": "0.1.0",
  "private": true,
  "description": "IRIS — Executive OS. Multi-tenant AI intelligence layer.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace shared",
    "build:server": "npm run build --workspace server",
    "build:web": "npm run build --workspace web",
    "build": "npm run build:shared && npm run build:server && npm run build:web",
    "dev": "concurrently -n shared,server,web -c blue,green,magenta \"npm:dev:shared\" \"npm:dev:server\" \"npm:dev:web\"",
    "dev:shared": "npm run dev --workspace shared",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "typecheck": "npm run typecheck --workspace shared && npm run typecheck --workspace server && npm run typecheck --workspace web",
    "lint": "eslint \"shared/src/**/*.ts\" \"server/src/**/*.ts\" \"web/src/**/*.{ts,tsx}\" --max-warnings 0",
    "db:migrate": "npm run db:migrate --workspace server",
    "db:status": "npm run db:status --workspace server",
    "db:seed": "npm run db:seed --workspace server",
    "db:seed:demo": "npm run db:seed:demo --workspace server",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
