# ──────────────────────────────────────────────────────────────────────────
# IRIS environment configuration
# Copy to `.env` and fill in. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── Runtime ──
NODE_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:8080
# Where the browser is redirected after sign-in (the web app origin; in dev = Vite).
WEB_BASE_URL=http://localhost:5173
# Comma-separated list of allowed browser origins (the Vite dev server, prod web origin).
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
LOG_LEVEL=info

# ── Database (MySQL) ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=IRIS
DB_CONNECTION_LIMIT=10

# ── Anthropic ──
ANTHROPIC_API_KEY=sk-ant-...
# Default model used by the Context Engine / chat. Confirm latest IDs at build time.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Security ──
# 32+ random bytes (base64/hex). Used to sign session cookies / JWTs.
SESSION_SECRET=replace-with-long-random-string
# Exactly 32 bytes (hex = 64 chars). Encrypts connector OAuth tokens at rest.
TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars

# ── Auth ──
# Session cookie name + lifetime.
COOKIE_NAME=iris_session
SESSION_TTL_DAYS=30
# Enable email/password sign-in alongside SSO (default false → Google SSO only).
AUTH_PASSWORD_ENABLED=false
# Restrict SSO to these email domains (comma-separated). Empty = any verified domain
# may self-provision a tenant — set this in production (e.g. lenskart.com).
AUTH_ALLOWED_DOMAINS=

# ── Google OAuth (SSO + Google connectors share one client) ──
# Create at: Google Cloud Console → APIs & Services → Credentials → OAuth client ID → Web application
# GMAIL_CLIENT_ID / GMAIL_CLIENT_SECRET are also accepted as aliases.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
# Connector authorization callback — ALSO add this to the Google OAuth client's
# authorized redirect URIs (used by "Connect Google" on the Connectors page).
GOOGLE_CONNECTOR_REDIRECT_URI=http://localhost:8080/api/connectors/google/callback

# Background workers (token refresh, health). Set false in tests.
WORKERS_ENABLED=true

# ── Seed (local dev convenience: `npm run db:seed`) ──
SEED_OWNER_EMAIL=owner@demo.local
SEED_OWNER_NAME=Demo Owner
SEED_OWNER_PASSWORD=iris-demo-password
SEED_TENANT_NAME=Demo Workspace
